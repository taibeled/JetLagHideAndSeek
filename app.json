{
    "expo": {
        "name": "Hide & Seek Mapper v2",
        "slug": "jet-lag-hide-and-seek-v2",
        "scheme": "jetlag-hide-seek-v2",
        "version": "0.1.1",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.raycatdev.hideandseek.v2",
            "infoPlist": {
                "NSLocationWhenInUseUsageDescription": "Your location is shown on the map so you can see where you are relative to the current Hide & Seek play area. Location is never stored or shared."
            }
        },
        "android": {
            "package": "com.raycatdev.hideandseek.v2",
            "appVersionSource": "remote",
            "predictiveBackGestureEnabled": false
        },
        "plugins": [
            "expo-router",
            "@maplibre/maplibre-react-native",
            "expo-splash-screen"
        ],
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#0D0D0F"
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "b799de35-fad5-42b8-8cd2-cd64e67ec828"
            }
        },
        "owner": "raycatdev"
    }
}
